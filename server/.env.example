# ── Server ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Auth ───────────────────────────────────────────────
# Generate a long random string, e.g.  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
TOKEN_TTL_DAYS=365
CODE_TTL_MIN=10

# Password for the /admin dashboard (usage report + CSV export + backup
# download). Generate one the same way, e.g. openssl rand -hex 16
ADMIN_KEY=change-me-to-a-long-random-string

# ── Database ───────────────────────────────────────────
# Relative to the server/ folder, or an absolute path.
SQLITE_PATH=./data/sim.db

# ── Email (transactional provider SMTP) ────────────────
# Works with Brevo / Postmark / Resend / Mailgun etc.
# If SMTP_* are blank, codes are only logged to the server console (dev).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Portfolio Simulator <no-reply@yourdomain.com>"

# ── Dev only ───────────────────────────────────────────
# Comma-separated origins allowed for CORS during local dev.
# In production the app is same-origin behind nginx — leave blank.
CORS_ORIGIN=http://localhost:5173
