# Base URL for the backend API.
# Leave unset in production — the app defaults to "/api" (same-origin, behind nginx).
# Only set this if the API lives on a different origin.
# VITE_API_URL=/api

# App version shown on the startup screen. Set at build time (e.g. from the
# CI tag or a Docker build arg) — not VITE_-prefixed since it's plumbed through
# vite.config.js's `define`.
# SIM_VERSION=1.0.0
